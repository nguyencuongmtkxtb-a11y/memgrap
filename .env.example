# === Required ===
# OpenAI — used for both LLM extraction (gpt-4o-mini) and embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-proj-...

# === Neo4j Connection ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# === Optional Tuning ===
# LLM_MODEL=gpt-4o-mini
# LLM_SMALL_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# GROUP_ID=default
# SEMAPHORE_LIMIT=5
